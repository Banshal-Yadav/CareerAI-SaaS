# --- Frontend Keys (For React / Vite) ---
# Get these from Firebase Console → Project Settings → General → Your Apps → Web App Config
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Backend Keys (For Vercel / api folder) ---
# Get this from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Gemini model name (defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Optional: Comma-separated origins allowed to call /api/analyze (e.g., https://your-domain.com,http://localhost:5173)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: enable admin-only pro toggle endpoint (/api/admin/set-pro)
# Comma-separated list of admin emails allowed to call it.
ADMIN_EMAILS=

# Firebase Admin SDK (For server-side operations in api/analyze.js)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Private_Key_Here\n-----END PRIVATE KEY-----\n"
